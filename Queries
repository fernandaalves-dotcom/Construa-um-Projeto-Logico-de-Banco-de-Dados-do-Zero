------ Qual modelo de veiculo, esteve mais presente na Oficina?----


SELECT V.Modelo, COUNT(os.id_os) AS total_ordens
FROM Ordem_de_serviço os
JOIN Veiculo V 
ON os.IDveiculo = V.IdVeiculo
GROUP BY V.modelo
ORDER BY total_ordens DESC;


------Clientes que tem mais de 1 ordem de serviço---


SELECT c.Nome, COUNT(os.id_os) AS quantidade_os
FROM Cliente c
JOIN Ordem_de_serviço os 
ON c.IdCliente = os.IDcliente
GROUP BY c.Nome
HAVING COUNT(os.Id_os) > 1
ORDER BY quantidade_os DESC;


