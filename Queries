---- O Mecanico  que mais atendeu----

SELECT f.nome, COUNT(s.Idserviço) AS total_servicos
FROM Serviço s
JOIN Funcionario f 
ON s.Id_funcionario = f.idfuncionario
GROUP BY f.nome
ORDER BY total_servicos DESC;


-----Quantas ordens de serviço, ainda estão com pagamento pendente?----


SELECT c.Nome, p.Idpagamento, p.Forma_pagamento, p.Status_pagamento
FROM Pagamentos p
JOIN Ordem_de_serviço os 
ON p.Id_ordem = os.Id_os
JOIN Cliente c 
ON os.IDcliente = c.IdCliente
WHERE p.Status_pagamento = 'Pendente';






